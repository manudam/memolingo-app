<?xml version="1.0" encoding="utf-8"?>
<!-- Clean blue gradient splash screen matching Flutter splash -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Blue gradient background matching app theme -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2563EB"
                android:centerColor="#1E40AF"
                android:endColor="#1E3A8A"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
</layer-list>

